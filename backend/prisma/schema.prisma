generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserLevel {
  beginner
  intermediate
  advanced
}

enum HealthStatus {
  healthy
  warning
  critical
  unknown
}

enum EventType {
  watering
  fertilization
  pruning
}

enum AlertType {
  disease
  dehydration
  overwatering
  general
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  level         UserLevel @default(beginner)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  plants        Plant[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([identifier, value])
  @@map("verifications")
}

model Plant {
  id           String         @id @default(uuid())
  userId       String         @map("user_id")
  name         String
  species      String?
  location     String
  createdAt    DateTime       @default(now()) @map("created_at")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  images       PlantImage[]
  diagnoses    Diagnosis[]
  careSchedule CareSchedule?
  events       CareEvent[]
  alerts       Alert[]

  @@index([userId])
  @@map("plants")
}

model PlantImage {
  id         String   @id @default(uuid())
  plantId    String   @map("plant_id")
  imagePath  String   @map("image_path")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  plant      Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([plantId])
  @@map("plant_images")
}

model Diagnosis {
  id                   String       @id @default(uuid())
  plantId              String       @map("plant_id")
  diagnosis            Json
  healthStatus         HealthStatus @default(unknown) @map("health_status")
  recommendations      String
  probableSpecies      String?      @map("probable_species")
  possibleDiseases     Json?        @map("possible_diseases")
  wateringFrequencyDays Int?        @map("watering_frequency_days")
  careTips             Json?        @map("care_tips")
  createdAt            DateTime     @default(now()) @map("created_at")
  plant                Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([plantId])
  @@map("diagnoses")
}

model CareSchedule {
  id                  String   @id @default(uuid())
  plantId             String   @unique @map("plant_id")
  wateringIntervalDays Int     @map("watering_interval_days")
  nextWateringDate    DateTime @map("next_watering_date")
  notes               String?
  plant               Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("care_schedules")
}

model CareEvent {
  id        String   @id @default(uuid())
  plantId   String   @map("plant_id")
  type      EventType
  eventDate DateTime @map("event_date")
  note      String?
  plant     Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([plantId, eventDate])
  @@map("care_events")
}

model PlantLibraryEntry {
  id                  String @id @default(uuid())
  name                String @unique
  characteristics     String
  generalInstructions String @map("general_instructions")

  @@map("plant_library")
}

model Alert {
  id        String    @id @default(uuid())
  plantId   String    @map("plant_id")
  type      AlertType @default(general)
  message   String
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at")
  plant     Plant     @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([plantId, createdAt])
  @@map("alerts")
}
